<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Gato Misterioso</title>

    <style>
        body {
            background-color: rgb(134, 56, 153);
            color: white;
            font-family: Arial, sans-serif;
            text-align: center;
        }

        header {
            background: #8b31c7;
            padding: 20px;
            font-size: 25px;
        }

        img {
            width: 250px;
            margin-top: 20px;
            border-radius: 10px;
        }

        .descricao {
            margin: 20px;
            font-size: 18px;
        }

        button {
            background: #8b31c7;
            color: white;
            border: none;
            padding: 10px;
            margin: 10px;
            border-radius: 8px;
            cursor: pointer;
        }

        button:hover {
            transform: scale(1.05);
        }
    </style>
</head>

<body>

    <header>
        Gato Risonho
    </header>

    <img src="/imagens/imagem1.jpg">

    <div class="descricao">
        <p><strong>Nome:</strong> Risos</p>
        <p><strong>Idade:</strong> 10 séculos</p>
        <p><strong>Especialidade:</strong> Rir</p>
        <p><strong>Habilidade:</strong> Rir sozinho</p>
    </div>

    <button>Quero</button>

    <br>

    <a href="/">
        <button>Voltar</button>
    </a>

</body>
</html>
